{
  "name": "semver-action",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "clean": "npx rimraf dist dist-ts",
    "compile": "npx tsc -p tsconfig.json",
    "bundle": "npx ncc build dist-ts/index.js -o dist --minify",
    "build": "npm run clean && npm run compile && npm run bundle"
  },
  "dependencies": {
    "@actions/core": "^2.0.2",
    "@actions/exec": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rimraf": "^6.1.2",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.3",
    "typescript": "^5.0.0"
  }
}